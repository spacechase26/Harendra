---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { profile } from '../content/profile';

const statusLabel: Record<string, string> = {
  done: 'Done',
  current: 'Now',
  next: 'Ahead',
};
---

<Base>
  <!-- ============ HERO ============ -->
  <header id="top" class="hero">
    <div class="container">
      <p class="hero__eyebrow eyebrow">
        <span class="hero__eyedot" aria-hidden="true"></span>{profile.location} · CA Aspirant
      </p>

      <h1 class="hero__name font-display">
        <span class="hero__mask"><span class="hero__inner">{profile.name}</span></span>
      </h1>
      <span class="hero__under" aria-hidden="true"></span>

      <p class="hero__tagline measure">{profile.tagline}</p>

      <p class="hero__now font-mono">
        <span class="dot" aria-hidden="true"></span>{profile.now}
      </p>
    </div>
  </header>

  <!-- ============ ABOUT ============ -->
  <section id="about" class="section">
    <div class="container">
      <SectionTitle num="01" label="About" tone="red" />
      <p class="lead measure" data-reveal>{profile.intro}</p>
    </div>
  </section>

  <!-- ============ PROJECTS ============ -->
  <section id="projects" class="section">
    <div class="container">
      <SectionTitle num="02" label="Projects" tone="blue" />
      {profile.projects.length === 0 ? (
        <p class="proj__empty font-display measure" data-reveal>{profile.projectsNote}</p>
      ) : (
        <ul class="proj">
          {profile.projects.map((p, i) => (
            <li class="proj__card" data-reveal>
              <div class="proj__top font-mono">
                <span class="proj__idx">{String(i + 1).padStart(2, '0')}</span>
                <span class="proj__meta">
                  {p.draft && <span class="proj__tag">sample</span>}
                  {p.year && <span class="proj__year">{p.year}</span>}
                </span>
              </div>
              <h3 class="proj__title font-display">
                {p.href ? (
                  <a href={p.href} target="_blank" rel="noopener noreferrer">{p.title} <span aria-hidden="true">↗</span></a>
                ) : (
                  p.title
                )}
              </h3>
              <p class="proj__blurb">{p.blurb}</p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- ============ JOURNEY ============ -->
  <section id="journey" class="section">
    <div class="container">
      <SectionTitle num="03" label="The Journey" tone="green" />
      <ol class="journey">
        {profile.journey.map((j) => (
          <li class={`jrow jrow--${j.status}`} data-reveal>
            <span class="jrow__when font-mono">{j.when}</span>
            <span class="jrow__body">
              <span class="jrow__title font-display">{j.title}</span>
              <span class="jrow__detail">{j.detail}</span>
            </span>
            <span class={`jrow__status font-mono jrow__status--${j.status}`}>{statusLabel[j.status]}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ CONTACT (dark band) ============ -->
  <section id="contact" class="section section--dark">
    <div class="container">
      <SectionTitle num="04" label="Get in touch" tone="dark" />
      <div class="contact" data-reveal>
        <p class="contact__cue font-display">Let's talk.</p>
        <a class="contact__email font-display" href={`mailto:${profile.email}`}>{profile.email}</a>
        {profile.socials.length > 0 && (
          <ul class="contact__socials font-mono">
            {profile.socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label} <span aria-hidden="true">→</span></a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    padding-top: clamp(64px, 14vh, 160px);
    padding-bottom: var(--section-y);
  }
  .hero__eyebrow { margin-bottom: var(--s-5); display: inline-flex; align-items: center; gap: var(--s-2); }
  .hero__eyedot { width: 9px; height: 9px; background: var(--accent); border-radius: 1px; }
  .hero__name {
    font-size: var(--t-name);
    line-height: 0.92;
    letter-spacing: -0.01em;
  }
  .hero__mask { display: inline-block; overflow: hidden; padding-bottom: 0.06em; }
  .hero__inner { display: inline-block; will-change: transform; }
  .hero__under {
    display: block;
    height: 4px;
    width: min(300px, 62%);
    background: var(--accent);
    border-radius: 2px;
    margin-top: var(--s-4);
    transform-origin: left center;
  }
  .hero__tagline {
    font-size: var(--t-lead);
    color: var(--ink-2);
    line-height: 1.4;
    margin-top: var(--s-6);
  }
  .hero__now {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    margin-top: var(--s-6);
    font-size: var(--t-mono);
    letter-spacing: 0.04em;
    color: var(--ink-mute);
  }
  .hero__now .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 60%, transparent);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 55%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__now .dot { animation: none; }
  }

  /* ---------- shared section ---------- */
  .section { padding-block: var(--section-y); }
  .lead { font-size: var(--t-lead); line-height: 1.5; color: var(--ink-2); }

  /* ---------- PROJECTS ---------- */
  .proj__empty {
    font-size: var(--t-h2);
    font-style: italic;
    line-height: 1.25;
    color: var(--ink);
  }
  .proj {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-5);
  }
  @media (max-width: 720px) { .proj { grid-template-columns: 1fr; } }
  .proj__card {
    border: 1px solid var(--rule-2);
    background: var(--paper);
    padding: var(--s-6);
    border-radius: 3px;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }
  .proj__card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--blue);
    border-color: var(--ink);
  }
  @media (prefers-reduced-motion: reduce) {
    .proj__card:hover { transform: none; }
  }
  .proj__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--s-4);
    font-size: var(--t-mono);
  }
  .proj__idx { color: var(--blue); }
  .proj__meta { display: inline-flex; align-items: center; gap: var(--s-3); }
  .proj__year { color: var(--ink-mute); font-size: var(--t-micro); }
  .proj__tag {
    font-size: var(--t-micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    border: 1px solid color-mix(in srgb, var(--blue) 55%, transparent);
    border-radius: 999px;
    padding: 2px 9px;
  }
  .proj__title { font-size: var(--t-h3); margin-bottom: var(--s-3); }
  .proj__title a { transition: color var(--dur-fast) var(--ease); }
  .proj__title a:hover { color: var(--blue); }
  .proj__blurb { color: var(--ink-2); }

  /* ---------- JOURNEY ---------- */
  .journey { list-style: none; }
  .jrow {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    gap: var(--s-5);
    align-items: start;
    padding: var(--s-5) 0;
    border-top: 1px solid var(--rule);
    position: relative;
  }
  .jrow:last-child { border-bottom: 1px solid var(--rule); }
  .jrow--current {
    background: linear-gradient(90deg, var(--accent-soft), transparent 55%);
  }
  .jrow__when { color: var(--ink-mute); font-size: var(--t-mono); padding-top: 0.35em; }
  .jrow__title { font-size: var(--t-h3); display: block; margin-bottom: var(--s-2); }
  .jrow__detail { color: var(--ink-mute); font-size: var(--t-body); line-height: 1.5; }
  .jrow__status {
    font-size: var(--t-micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule-2);
    border-radius: 999px;
    color: var(--ink-mute);
    white-space: nowrap;
    align-self: start;
    margin-top: 0.25em;
  }
  .jrow__status--done {
    color: var(--green);
    border-color: color-mix(in srgb, var(--green) 45%, transparent);
    background: var(--green-soft);
  }
  .jrow__status--current {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .jrow__status--next {
    color: var(--blue);
    border-color: color-mix(in srgb, var(--blue) 45%, transparent);
  }
  @media (max-width: 640px) {
    .jrow { grid-template-columns: 1fr auto; }
    .jrow__when { grid-column: 1 / -1; padding-top: 0; }
  }

  /* ---------- CONTACT (dark band) ---------- */
  .section--dark {
    background: var(--ink-deep);
    color: var(--on-dark);
    padding-block: clamp(72px, 12vh, 140px);
  }
  .section--dark :global(.stitle__line) { background: rgba(237, 231, 217, 0.16); }
  .section--dark :global(.stitle__label) { color: var(--on-dark-mute); }
  .contact { display: flex; flex-direction: column; gap: var(--s-5); align-items: flex-start; }
  .contact__cue {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    line-height: 1;
    margin-bottom: var(--s-3);
  }
  .contact__email {
    font-size: var(--t-h2);
    color: var(--on-dark);
    width: fit-content;
    border-bottom: 2px solid rgba(237, 231, 217, 0.25);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .contact__email:hover { border-color: var(--blue-bright); color: var(--blue-bright); }
  .contact__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
    list-style: none;
    font-size: var(--t-mono);
    letter-spacing: 0.04em;
    margin-top: var(--s-3);
  }
  .contact__socials a { color: var(--on-dark-mute); transition: color var(--dur-fast) var(--ease); }
  .contact__socials a:hover { color: var(--blue-bright); }
</style>

<!-- hero entrance animation -->
<script>
  import { gsap } from 'gsap';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const inner = document.querySelector('.hero__inner');
  const under = document.querySelector('.hero__under');
  const eyebrow = document.querySelector('.hero__eyebrow');
  const tagline = document.querySelector('.hero__tagline');
  const now = document.querySelector('.hero__now');

  if (!reduce && inner) {
    gsap.set([eyebrow, tagline, now], { opacity: 0, y: 16 });
    gsap.set(inner, { yPercent: 115 });
    gsap.set(under, { scaleX: 0 });

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.to(eyebrow, { opacity: 1, y: 0, duration: 0.5 }, 0.05)
      .to(inner, { yPercent: 0, duration: 1.05, ease: 'expo.out' }, 0.12)
      .to(under, { scaleX: 1, duration: 0.7, ease: 'power4.inOut' }, 0.55)
      .to(tagline, { opacity: 1, y: 0, duration: 0.6 }, 0.6)
      .to(now, { opacity: 1, y: 0, duration: 0.6 }, 0.75);
  }
</script>
