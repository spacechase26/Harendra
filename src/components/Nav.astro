---
import { profile } from '../content/profile';
const links = [
  { href: '#about',   label: 'About' },
  { href: '#focus',   label: 'Focus' },
  { href: '#journey', label: 'Journey' },
  { href: '#contact', label: 'Contact' },
];
const base = import.meta.env.BASE_URL;
---

<nav class="nav">
  <div class="container nav__inner">
    <a href={base} class="nav__mark font-mono" aria-label={`${profile.name} — home`}>HK<span>.</span></a>
    <ul class="nav__links font-mono">
      {links.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </div>
  <hr class="rule" />
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(1.1) blur(8px);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav__mark {
    font-size: var(--t-mono);
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--ink);
  }
  .nav__mark span { color: var(--accent); }
  .nav__links {
    display: flex;
    gap: var(--s-5);
    list-style: none;
    font-size: var(--t-mono);
    letter-spacing: 0.06em;
  }
  .nav__links a {
    color: var(--ink-mute);
    padding-block: 4px;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .nav__links a:hover {
    color: var(--ink);
    border-color: var(--accent);
  }
  @media (max-width: 540px) {
    .nav__links { gap: var(--s-4); }
    .nav__links li:nth-child(2) { display: none; } /* drop "Focus" on tiny screens */
  }
</style>
